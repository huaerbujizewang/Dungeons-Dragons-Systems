{
    "title": "行万里路",
    "date": "DR1491 - 8月",
    "typeSpeed": 26,
    "autoDelay": 900,
    "bg": "jing_courtyard_spring_rain",
    "assets": {
        "jing_courtyard_spring_rain": "assets/stories/backgrounds/jing_courtyard_spring_rain.png",
