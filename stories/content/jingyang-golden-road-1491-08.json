    },
    "characters": {
        "jingyang": {
            "name": "景阳",
            "sprites": {
                "calm": "jingyang_avatar_calm",
                "resolved": "jingyang_avatar_resolved",
                "respectful": "jingyang_avatar_respectful"
            }
        },
        "fubo": {
            "name": "福伯",
            "sprites": {
                "worried": "fubo_avatar_worried",
                "gentle": "fubo_avatar_gentle"
            }
        },
        "jing_father": {
            "name": "景老爷子",
            "sprites": {
                "stern": "jing_father_avatar_stern",
